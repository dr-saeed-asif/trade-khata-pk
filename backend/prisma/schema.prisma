// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum AlertType {
  LOW_STOCK
  EXPIRY
  OVERSTOCK
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum StockAdjustmentReason {
  DAMAGE
  LOSS
  RECOUNT
  MANUAL
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum TransactionStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

model User {
  id           String        @id @default(uuid())
  name         String
  username     String?       @unique
  email        String        @unique
  passwordHash String
  role         UserRole      @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  scans        ScanHistory[]
  activities   ActivityLog[]
  audits       AuditTrail[]
  stockMovements StockMovement[]
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     Item[]
  itemLinks ItemCategory[]
}

model CatalogSeedExclusion {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Item {
  id          String        @id @default(uuid())
  name        String
  sku         String        @unique
  quantity    Int
  reservedQty Int           @default(0)
  expiryDate  DateTime?
  weight      String?
  expiryMessage String?
  price       Decimal       @db.Decimal(10, 2)
  supplier    String
  location    String
  description String?
  qrValue     String        @unique
  barcodeValue String       @unique
  lowStockAt  Int           @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  categoryId  String
  locationId  String?
  category    Category      @relation(fields: [categoryId], references: [id])
  storageLocation StorageLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  scans       ScanHistory[]
  activities  ActivityLog[]
  audits      AuditTrail[]
  categories  ItemCategory[]
  tags        ItemTag[]
  variants    ItemVariant[]
  stockMovements StockMovement[]
  batches     ItemBatch[]
  alerts      Alert[]
  saleLines     SaleLine[]
  purchaseLines PurchaseLine[]
}

model Party {
  id        String    @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  type      PartyType @default(BOTH)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sales     Sale[]
  purchases Purchase[]

  @@index([name])
  @@index([type])
}

model Sale {
  id          String            @id @default(uuid())
  invoiceNo   String            @unique
  partyId     String?
  status      TransactionStatus @default(CONFIRMED)
  saleDate    DateTime          @default(now())
  subtotal    Decimal           @db.Decimal(12, 2)
  discount    Decimal           @default(0) @db.Decimal(12, 2)
  total       Decimal           @db.Decimal(12, 2)
  notes       String?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  party       Party?            @relation(fields: [partyId], references: [id], onDelete: SetNull)
  lines       SaleLine[]

  @@index([saleDate])
  @@index([partyId])
}

model SaleLine {
  id        String  @id @default(uuid())
  saleId    String
  itemId    String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(12, 2)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  item      Item    @relation(fields: [itemId], references: [id])

  @@index([saleId])
  @@index([itemId])
}

model Purchase {
  id          String            @id @default(uuid())
  invoiceNo   String            @unique
  partyId     String?
  status      TransactionStatus @default(CONFIRMED)
  purchaseDate DateTime         @default(now())
  subtotal    Decimal           @db.Decimal(12, 2)
  discount    Decimal           @default(0) @db.Decimal(12, 2)
  total       Decimal           @db.Decimal(12, 2)
  notes       String?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  party       Party?            @relation(fields: [partyId], references: [id], onDelete: SetNull)
  lines       PurchaseLine[]

  @@index([purchaseDate])
  @@index([partyId])
}

model PurchaseLine {
  id         String   @id @default(uuid())
  purchaseId String
  itemId     String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  lineTotal  Decimal  @db.Decimal(12, 2)
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item       Item     @relation(fields: [itemId], references: [id])

  @@index([purchaseId])
  @@index([itemId])
}

model Warehouse {
  id          String            @id @default(uuid())
  name        String
  code        String            @unique
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  locations   StorageLocation[]
}

model StorageLocation {
  id          String      @id @default(uuid())
  warehouseId String
  name        String
  shelf       String
  rack        String
  bin         String
  qrValue     String      @unique
  barcodeValue String     @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  items       Item[]

  @@unique([warehouseId, shelf, rack, bin])
}

model ItemBatch {
  id          String   @id @default(uuid())
  itemId      String
  batchNumber String
  lotNumber   String?
  expiryDate  DateTime?
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id               String               @id @default(uuid())
  itemId           String
  type             StockMovementType
  quantity         Int
  beforeQty        Int
  afterQty         Int
  note             String?
  reference        String?
  sourceWarehouse  String?
  destinationWarehouse String?
  adjustmentReason StockAdjustmentReason?
  createdAt        DateTime @default(now())
  userId           String?
  item             Item                 @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user             User?                @relation(fields: [userId], references: [id])
}

model ItemCategory {
  itemId     String
  categoryId String
  createdAt  DateTime @default(now())
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([itemId, categoryId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     ItemTag[]
}

model ItemTag {
  itemId     String
  tagId      String
  createdAt  DateTime @default(now())
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
}

model ItemVariant {
  id          String   @id @default(uuid())
  itemId      String
  name        String?
  sku         String   @unique
  size        String?
  color       String?
  model       String?
  quantity    Int      @default(0)
  reservedQty Int      @default(0)
  price       Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ScanHistory {
  id        String   @id @default(uuid())
  qrCode    String
  note      String?
  createdAt DateTime @default(now())
  itemId    String
  userId    String?
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  description String?
  createdAt   DateTime @default(now())
  userId      String?
  itemId      String?
  user        User?    @relation(fields: [userId], references: [id])
  item        Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
}

model AuditTrail {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  oldData    Json?
  newData    Json?
  createdAt  DateTime @default(now())
  userId     String?
  itemId     String?
  user       User?    @relation(fields: [userId], references: [id])
  item       Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
}

model Alert {
  id          String         @id @default(uuid())
  dedupeKey   String         @unique
  type        AlertType
  severity    AlertSeverity
  title       String
  message     String         @db.Text
  itemId      String?
  payload     Json?
  isRead      Boolean        @default(false)
  readAt      DateTime?
  resolvedAt  DateTime?
  inAppSentAt DateTime?
  emailSentAt DateTime?
  desktopSentAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  item        Item?          @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([type, severity, isRead])
  @@index([itemId])
}
