# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/qr_inventory?schema=public"

# Auth
JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="1d"
PORT=4000

# Admin seed user
ADMIN_NAME="System Admin"
ADMIN_EMAIL="admin@test.local"
ADMIN_PASSWORD="Test123"

# --- Qwen Cloud (recommended) ---
# Dashboard: https://www.qwencloud.com → API Keys
LLM_PROVIDER=qwen
LLM_API_KEY=sk-ws-YOUR_QWEN_CLOUD_API_KEY
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=800
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=2

# AI memory
AI_MAX_CONTEXT_MESSAGES=20
AI_CONVERSATION_SUMMARY_THRESHOLD=30
